{
  "port": 5000,
  "tls_cert": "",
  "tls_key": "",
  "token_expiry": "24h",
  "max_concurrent": 50,
  "buffer_size": 1048576,
  "log_level": "info",
  "data_persistence": false,
  "data_file": "/tmp/registry-proxy-data.json",
  "connection_pool_size": 100,
  "request_timeout": "60s",
  "upstreams": [
    {
      "name": "gcr",
      "registry": "gcr.io",
      "route_pattern": "gcr.io/*"
          },
    {
      "name": "harbor",
      "registry": "harbor.company.com",
      "route_pattern": "private/*"
    },
    {
      "name": "dockerhub",
      "registry": "registry-1.docker.io",
      "route_pattern": "*"
    }
  ]
} 